            {
              "id": "8e11a790-eec0-31f0-b074-9a4137edd510",
              "name": "resources.rules.go.go-session-error-ignored",
              "shortDescription": {
                "text": "Opengrep Finding: resources.rules.go.go-session-error-ignored"
              },
              "fullDescription": {
                "text": "Gorilla session.Get() error is silently ignored. If session decoding fails due to a tampered or expired cookie, the returned session will be a new empty session. Code that subsequently performs type assertions on session values will panic or silently treat an unauthenticated user as authenticated. Always check the error from session.Get().\n"
              },
              "defaultConfiguration": {
                "enabled": true,
                "level": "warning"
              },
              "help": {
                "text": "Gorilla session.Get() error is silently ignored. If session decoding fails due to a tampered or expired cookie, the returned session will be a new empty session. Code that subsequently performs type assertions on session values will panic or silently treat an unauthenticated user as authenticated. Always check the error from session.Get().\n",
                "markdown": "Gorilla session.Get() error is silently ignored. If session decoding fails due to a tampered or expired cookie, the returned session will be a new empty session. Code that subsequently performs type assertions on session values will panic or silently treat an unauthenticated user as authenticated. Always check the error from session.Get().\n\n\n<b>References:</b>\n - [https://pkg.go.dev/github.com/gorilla/sessions#Store](https://pkg.go.dev/github.com/gorilla/sessions#Store)\n"
              },
              "properties": {
                "cwe": [
                  {
                    "id": "CWE-390",
                    "url": "https://cwe.mitre.org/data/definitions/390.html"
                  }
                ],
                "security-severity": "5.0",
                "precision": "very-high",
                "tags": [
                  "CWE-390",
                  "security"
                ]
              }
            },
