            {
              "id": "92c19204-f1a0-3470-851c-a5ad5380d249",
              "name": "resources.rules.go.go-tls-insecure-skip-verify",
              "shortDescription": {
                "text": "Opengrep Finding: resources.rules.go.go-tls-insecure-skip-verify"
              },
              "fullDescription": {
                "text": "TLS certificate verification is disabled via InsecureSkipVerify: true. This disables all TLS certificate validation, making the connection vulnerable to man-in-the-middle attacks. Remove InsecureSkipVerify or set it to false. For custom CA certificates use tls.Config.RootCAs.\n"
              },
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "help": {
                "text": "TLS certificate verification is disabled via InsecureSkipVerify: true. This disables all TLS certificate validation, making the connection vulnerable to man-in-the-middle attacks. Remove InsecureSkipVerify or set it to false. For custom CA certificates use tls.Config.RootCAs.\n",
                "markdown": "TLS certificate verification is disabled via InsecureSkipVerify: true. This disables all TLS certificate validation, making the connection vulnerable to man-in-the-middle attacks. Remove InsecureSkipVerify or set it to false. For custom CA certificates use tls.Config.RootCAs.\n\n\n<b>References:</b>\n - [https://pkg.go.dev/crypto/tls#Config](https://pkg.go.dev/crypto/tls#Config)\n"
              },
              "properties": {
                "cwe": [
                  {
                    "id": "CWE-295",
                    "url": "https://cwe.mitre.org/data/definitions/295.html"
                  }
