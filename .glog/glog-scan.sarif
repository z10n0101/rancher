              "name": "resources.rules.go.go.lang.security.audit.http.content-disposition-filename-unsanitized.content-disposition-filename-unsanitized",
              "shortDescription": {
                "text": "Opengrep Finding: resources.rules.go.go.lang.security.audit.http.content-disposition-filename-unsanitized.content-disposition-filename-unsanitized"
              },
              "fullDescription": {
                "text": "User-influenced filename is written into `Content-Disposition` via `%s` formatting without explicit sanitization/quoting. This can enable header injection or unsafe client behavior."
              },
              "defaultConfiguration": {
                "enabled": true,
                "level": "warning"
              },
              "help": {
                "text": "User-influenced filename is written into `Content-Disposition` via `%s` formatting without explicit sanitization/quoting. This can enable header injection or unsafe client behavior.",
