            {
              "id": "02deea5e-49de-3b31-80b7-607fc0ac2588",
              "name": "resources.rules.go.go-jwt-manual-split-no-verify",
              "shortDescription": {
                "text": "Opengrep Finding: resources.rules.go.go-jwt-manual-split-no-verify"
              },
              "fullDescription": {
                "text": "JWT token is decoded manually by splitting on \".\" and base64-decoding parts without cryptographic signature verification. An attacker can forge arbitrary tokens. Use jwt.Parse() or jwt.ParseWithClaims() with a KeyFunc that enforces the expected signing algorithm.\n"
              },
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "help": {
                "text": "JWT token is decoded manually by splitting on \".\" and base64-decoding parts without cryptographic signature verification. An attacker can forge arbitrary tokens. Use jwt.Parse() or jwt.ParseWithClaims() with a KeyFunc that enforces the expected signing algorithm.\n",
                "markdown": "JWT token is decoded manually by splitting on \".\" and base64-decoding parts without cryptographic signature verification. An attacker can forge arbitrary tokens. Use jwt.Parse() or jwt.ParseWithClaims() with a KeyFunc that enforces the expected signing algorithm.\n"
              },
              "properties": {
                "cwe": [
                  {
                    "id": "CWE-347",
                    "url": "https://cwe.mitre.org/data/definitions/347.html"
                  }
                ],
                "security-severity": "5.0",
                "precision": "very-high",
                "tags": [
                  "CWE-347",
                  "security"
                ]
              }
