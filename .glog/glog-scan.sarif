              "fullDescription": {
                "text": "Unsafe single-value type assertion in if-init statement. This will panic at runtime if the value does not hold the asserted type. Use the two-value form: if val, ok := $VAR.($TYPE); ok { ... } and check ok before using val.\n"
              },
              "defaultConfiguration": {
                "enabled": true,
                "level": "warning"
              },
