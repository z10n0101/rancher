            {
              "id": "f9429f6a-40ca-3b08-80ff-20602948eb24",
              "name": "resources.rules.go.go-jwt-parse-unverified",
              "shortDescription": {
                "text": "Opengrep Finding: resources.rules.go.go-jwt-parse-unverified"
              },
              "fullDescription": {
                "text": "jwt.ParseUnverified() skips signature verification entirely. Any JWT token, including attacker-forged tokens, will be accepted. This is a critical authentication failure. Always use jwt.Parse() or jwt.ParseWithClaims() with a proper keyfunc that verifies the signature against a trusted key.\n"
              },
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "help": {
                "text": "jwt.ParseUnverified() skips signature verification entirely. Any JWT token, including attacker-forged tokens, will be accepted. This is a critical authentication failure. Always use jwt.Parse() or jwt.ParseWithClaims() with a proper keyfunc that verifies the signature against a trusted key.\n",
                "markdown": "jwt.ParseUnverified() skips signature verification entirely. Any JWT token, including attacker-forged tokens, will be accepted. This is a critical authentication failure. Always use jwt.Parse() or jwt.ParseWithClaims() with a proper keyfunc that verifies the signature against a trusted key.\n"
              },
              "properties": {
                "cwe": [
                  {
                    "id": "CWE-347",
                    "url": "https://cwe.mitre.org/data/definitions/347.html"
                  }
                ],
                "security-severity": "5.0",
