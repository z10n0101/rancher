            {
              "id": "e29333ff-d8b9-3fa3-abd7-83d49cdc8489",
              "name": "resources.rules.go.go-xss-taint-response-write",
              "shortDescription": {
                "text": "Opengrep Finding: resources.rules.go.go-xss-taint-response-write"
              },
              "fullDescription": {
                "text": "Cross-Site Scripting (XSS): user-controlled data flows into an HTTP response without HTML escaping. An attacker can inject arbitrary HTML or JavaScript that executes in a victim's browser. Use html/template for rendering HTML, or call html.EscapeString() before writing user data to the response.\n"
              },
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "help": {
                "text": "Cross-Site Scripting (XSS): user-controlled data flows into an HTTP response without HTML escaping. An attacker can inject arbitrary HTML or JavaScript that executes in a victim's browser. Use html/template for rendering HTML, or call html.EscapeString() before writing user data to the response.\n",
                "markdown": "Cross-Site Scripting (XSS): user-controlled data flows into an HTTP response without HTML escaping. An attacker can inject arbitrary HTML or JavaScript that executes in a victim's browser. Use html/template for rendering HTML, or call html.EscapeString() before writing user data to the response.\n\n\n<b>References:</b>\n - [https://cheatsheetseries.owasp.org/cheatsheets/Cross_Site_Scripting_Prevention_Cheat_Sheet.html](https://cheatsheetseries.owasp.org/cheatsheets/Cross_Site_Scripting_Prevention_Cheat_Sheet.html)\n"
              },
              "properties": {
