              "fullDescription": {
                "text": "Import of deprecated io/ioutil package. Since Go 1.16 all functions have moved to io and os packages. Replace: ioutil.ReadAll -> io.ReadAll, ioutil.ReadFile -> os.ReadFile, ioutil.WriteFile -> os.WriteFile, ioutil.TempFile -> os.CreateTemp.\n"
              },
              "defaultConfiguration": {
