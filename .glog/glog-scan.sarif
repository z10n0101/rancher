              "shortDescription": {
                "text": "Opengrep Finding: resources.rules.go.go-jwt-manual-split-no-verify"
              },
              "fullDescription": {
                "text": "JWT token is decoded manually by splitting on \".\" and base64-decoding parts without cryptographic signature verification. An attacker can forge arbitrary tokens. Use jwt.Parse() or jwt.ParseWithClaims() with a KeyFunc that enforces the expected signing algorithm.\n"
              },
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
