            {
              "id": "ec42ffdd-862f-3a1f-aa67-4ac7852ed4d4",
              "name": "resources.rules.go.go-inputval-atoi-to-narrow-int",
              "shortDescription": {
                "text": "Opengrep Finding: resources.rules.go.go-inputval-atoi-to-narrow-int"
              },
              "fullDescription": {
                "text": "Integer overflow: the result of strconv.Atoi (platform-native int, up to 64 bits) is directly cast to a narrower integer type (int8, int16, int32, uint16, uint32). Values outside the target range will silently wrap. Use strconv.ParseInt with the correct bit-size argument and check the error instead of casting.\n"
              },
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "help": {
                "text": "Integer overflow: the result of strconv.Atoi (platform-native int, up to 64 bits) is directly cast to a narrower integer type (int8, int16, int32, uint16, uint32). Values outside the target range will silently wrap. Use strconv.ParseInt with the correct bit-size argument and check the error instead of casting.\n",
                "markdown": "Integer overflow: the result of strconv.Atoi (platform-native int, up to 64 bits) is directly cast to a narrower integer type (int8, int16, int32, uint16, uint32). Values outside the target range will silently wrap. Use strconv.ParseInt with the correct bit-size argument and check the error instead of casting.\n\n\n<b>References:</b>\n - [https://pkg.go.dev/strconv#ParseInt](https://pkg.go.dev/strconv#ParseInt)\n"
              },
              "properties": {
                "cwe": [
                  {
                    "id": "CWE-190",
                    "url": "https://cwe.mitre.org/data/definitions/190.html"
                  }
                ],
                "security-severity": "5.0",
                "precision": "very-high",
                "tags": [
                  "CWE-190",
                  "security"
                ]
              }
