              "name": "resources.rules.go.go-tls-insecure-skip-verify-indirect",
              "shortDescription": {
                "text": "Opengrep Finding: resources.rules.go.go-tls-insecure-skip-verify-indirect"
              },
              "fullDescription": {
                "text": "TLS InsecureSkipVerify is set to a variable value. If the variable is true at runtime, certificate verification is disabled, enabling man-in-the-middle attacks. Ensure the value is always false in production. Avoid making TLS verification configurable.\n"
              },
              "defaultConfiguration": {
                "enabled": true,
                "level": "warning"
              },
              "help": {
