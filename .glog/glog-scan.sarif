            {
              "id": "244cde75-b9ae-3d9a-9d85-772b3d548eba",
              "name": "resources.rules.go.go-ldap-plaintext-connection",
              "shortDescription": {
                "text": "Opengrep Finding: resources.rules.go.go-ldap-plaintext-connection"
              },
              "fullDescription": {
                "text": "LDAP connection established over plain TCP (ldap.Dial) without upgrading to TLS. All traffic including bind credentials is transmitted in cleartext and can be intercepted. Use ldap.DialTLS() for direct TLS, or call conn.StartTLS() immediately after ldap.Dial() before any bind.\n"
              },
              "defaultConfiguration": {
                "enabled": true,
                "level": "error"
              },
              "help": {
                "text": "LDAP connection established over plain TCP (ldap.Dial) without upgrading to TLS. All traffic including bind credentials is transmitted in cleartext and can be intercepted. Use ldap.DialTLS() for direct TLS, or call conn.StartTLS() immediately after ldap.Dial() before any bind.\n",
                "markdown": "LDAP connection established over plain TCP (ldap.Dial) without upgrading to TLS. All traffic including bind credentials is transmitted in cleartext and can be intercepted. Use ldap.DialTLS() for direct TLS, or call conn.StartTLS() immediately after ldap.Dial() before any bind.\n\n\n<b>References:</b>\n - [https://pkg.go.dev/gopkg.in/ldap.v2#DialTLS](https://pkg.go.dev/gopkg.in/ldap.v2#DialTLS)\n"
              },
              "properties": {
                "cwe": [
                  {
                    "id": "CWE-319",
                    "url": "https://cwe.mitre.org/data/definitions/319.html"
                  }
                ],
                "security-severity": "5.0",
                "precision": "very-high",
                "tags": [
                  "CWE-319",
                  "security"
                ]
              }
            },
